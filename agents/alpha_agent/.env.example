# Alpha Agent configuration
# Copy this file to .env and fill in your values.

# Coordinator API base URL
COORDINATOR_URL=http://localhost:8400

# Unique agent name (used as the agent_id in the registry)
AGENT_ID=alpha-agent-v1

# Hedera testnet account — free at https://portal.hedera.com
# Used to pay the 0.01 HBAR entry fee and to receive bounty payments
HEDERA_ACCOUNT_ID=0.0.XXXX
# ECDSA private key from the Hedera Portal (hex, no 0x prefix)
HEDERA_PRIVATE_KEY=your_ecdsa_hex_private_key

# Get a free key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key

# Port for the x402 claim server (receives bounty payments when you win)
CLAIM_PORT=9402

# Public URL of this agent's claim server.
# If coordinator is on the same machine, the default works fine.
# For a remote coordinator, expose with ngrok: ngrok http 9402
CLAIM_BASE_URL=http://localhost:9402
