# Hedera testnet credentials
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# ── Broadcaster ────────────────────────────────────────────────────────────────
# The parent agent: creates tasks, holds the bounty wallet, signs all payments.
# Must be a funded ECDSA testnet account (Hedera Portal creates ECDSA by default).
#
# The SDK reads exactly these two variable names — do not rename them.
OPERATOR_ID=0.0.xxxx
OPERATOR_KEY=

# ── Worker accounts (receive-only — no private keys needed) ───────────────────
WORKER_A_ACCOUNT_ID=0.0.yyyy
WORKER_B_ACCOUNT_ID=0.0.zzzz

# ── x402 / facilitator ────────────────────────────────────────────────────────
HEDERA_NETWORK=hedera:testnet
FACILITATOR_URL=https://api.testnet.blocky402.com

# ── LLM ───────────────────────────────────────────────────────────────────────
GROQ_API_KEY=
